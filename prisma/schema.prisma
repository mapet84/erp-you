// Prisma schema — ERP YOU · Fase 1 (Portal de Autofacturación CFDI 4.0)
// Slice #1: modelo Emisor para la resolución de tenant por slug.
// Slice #2: Emisor extendido con su config fiscal + referencia a Facturama.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Un emisor = un tenant del portal. Se resuelve por `slug` en /f/[slug].
model Emisor {
  id          String   @id @default(cuid())
  slug        String   @unique
  rfc         String
  razonSocial String
  /// Marca del portal público: { nombreComercial?, colorPrimario?, logoUrl? }
  branding    Json     @default("{}")
  activo      Boolean  @default(true)

  // --- Config fiscal (slice #2) ---
  /// Régimen fiscal del emisor (clave c_RegimenFiscal del SAT, p.ej. "601").
  regimenFiscal String?
  /// CP del lugar de expedición (LugarExpedicion del CFDI).
  cpExpedicion  String?
  /// Concepto genérico por emisor:
  /// { claveProdServ, claveUnidad, descripcion, tasaIva }
  conceptoDefault Json?
  /// Política de ventana de facturación. Default: mismo mes calendario.
  ventanaFacturacion String @default("MISMO_MES")
  /// Referencia del emisor en Facturama Multiemisor (se llena al cargar el CSD).
  facturamaIssuerRef String?

  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("emisores")
}

/// Una factura (CFDI) emitida por autofacturación. Slice #3: camino feliz.
model Invoice {
  id       String @id @default(cuid())
  emisor   Emisor @relation(fields: [emisorId], references: [id])
  emisorId String

  /// Folio del ticket capturado por el cliente (clave anti-duplicado en F1).
  folioTicket String
  /// Fecha del ticket capturada (para la regla de ventana de facturación, #7).
  fechaTicket DateTime?
  /// Montos del comprobante (con IVA desglosado en centavos por `tax`).
  total    Decimal @db.Decimal(12, 2)
  subtotal Decimal @db.Decimal(12, 2)
  iva      Decimal @db.Decimal(12, 2)

  // --- Datos fiscales del receptor capturados en el portal ---
  receptorRfc     String
  receptorNombre  String
  receptorCp      String
  receptorRegimen String
  usoCfdi         String
  formaPago       String
  email           String

  // --- Resultado del PAC ---
  /// Estatus de la factura: "timbrada" | "error" (rechazo del PAC, #8).
  estatus         String  @default("timbrada")
  /// Folio fiscal (UUID del timbre). Único cuando existe.
  uuid            String? @unique
  /// Id del CFDI en Facturama (para descargar PDF/XML en el slice #4).
  facturamaCfdiId String?
  /// Detalle del rechazo del PAC cuando estatus = "error" (#8).
  errorPac        String?

  // --- Entrega por correo (#5) ---
  /// ¿Se entregó la factura por correo? (complementario a la descarga).
  correoEnviado Boolean @default(false)
  /// Detalle del fallo de envío de correo, si lo hubo (para reintento).
  correoError   String?

  files InvoiceFile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Anti-duplicado (#7): un folio de ticket por emisor. Un row en estatus
  /// "error" se reintenta (se actualiza), uno "timbrada" bloquea el re-timbrado.
  @@unique([emisorId, folioTicket])
  @@map("invoices")
}

/// Archivo fiscal (XML/PDF) del CFDI, conservado como bytea (#4).
model InvoiceFile {
  id        String  @id @default(cuid())
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  /// "xml" | "pdf".
  tipo        String
  /// Bytes del archivo (XML o PDF ya decodificado de base64).
  contenido   Bytes
  /// Content-Type para servir la descarga (application/xml | application/pdf).
  contentType String

  createdAt DateTime @default(now())

  @@unique([invoiceId, tipo])
  @@map("invoice_files")
}

/// Catálogo del SAT sembrado en BD (#6): c_RegimenFiscal, c_UsoCFDI, c_FormaPago.
model CatalogoSat {
  id          String @id @default(cuid())
  /// "regimenFiscal" | "usoCfdi" | "formaPago".
  tipo        String
  clave       String
  descripcion String
  /// Orden de presentación en el dropdown.
  orden       Int    @default(0)

  @@unique([tipo, clave])
  @@map("catalogos_sat")
}
