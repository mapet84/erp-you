// Prisma schema — ERP YOU · Fase 1 (Portal de Autofacturación CFDI 4.0)
// Slice #1: modelo Emisor para la resolución de tenant por slug.
// Slice #2: Emisor extendido con su config fiscal + referencia a Facturama.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  // Fase 1 (portal CFDI) vive en `public`; el ERP (Fase 2) en `erp`.
  schemas   = ["public", "erp"]
}

/// Un emisor = un tenant del portal. Se resuelve por `slug` en /f/[slug].
model Emisor {
  id          String   @id @default(cuid())
  slug        String   @unique
  rfc         String
  razonSocial String
  /// Marca del portal público: { nombreComercial?, colorPrimario?, logoUrl? }
  branding    Json     @default("{}")
  activo      Boolean  @default(true)

  // --- Config fiscal (slice #2) ---
  /// Régimen fiscal del emisor (clave c_RegimenFiscal del SAT, p.ej. "601").
  regimenFiscal String?
  /// CP del lugar de expedición (LugarExpedicion del CFDI).
  cpExpedicion  String?
  /// Concepto genérico por emisor:
  /// { claveProdServ, claveUnidad, descripcion, tasaIva }
  conceptoDefault Json?
  /// Política de ventana de facturación. Default: mismo mes calendario.
  ventanaFacturacion String @default("MISMO_MES")
  /// Referencia del emisor en Facturama Multiemisor (se llena al cargar el CSD).
  facturamaIssuerRef String?

  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("emisores")
  @@schema("public")
}

/// Una factura (CFDI) emitida por autofacturación. Slice #3: camino feliz.
model Invoice {
  id       String @id @default(cuid())
  emisor   Emisor @relation(fields: [emisorId], references: [id])
  emisorId String

  /// Folio del ticket capturado por el cliente (clave anti-duplicado en F1).
  folioTicket String
  /// Fecha del ticket capturada (para la regla de ventana de facturación, #7).
  fechaTicket DateTime?
  /// Montos del comprobante (con IVA desglosado en centavos por `tax`).
  total    Decimal @db.Decimal(12, 2)
  subtotal Decimal @db.Decimal(12, 2)
  iva      Decimal @db.Decimal(12, 2)

  // --- Datos fiscales del receptor capturados en el portal ---
  receptorRfc     String
  receptorNombre  String
  receptorCp      String
  receptorRegimen String
  usoCfdi         String
  formaPago       String
  email           String

  // --- Resultado del PAC ---
  /// Estatus de la factura: "timbrada" | "error" (rechazo del PAC, #8).
  estatus         String  @default("timbrada")
  /// Folio fiscal (UUID del timbre). Único cuando existe.
  uuid            String? @unique
  /// Id del CFDI en Facturama (para descargar PDF/XML en el slice #4).
  facturamaCfdiId String?
  /// Detalle del rechazo del PAC cuando estatus = "error" (#8).
  errorPac        String?

  // --- Entrega por correo (#5) ---
  /// ¿Se entregó la factura por correo? (complementario a la descarga).
  correoEnviado Boolean @default(false)
  /// Detalle del fallo de envío de correo, si lo hubo (para reintento).
  correoError   String?

  files InvoiceFile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Anti-duplicado (#7): un folio de ticket por emisor. Un row en estatus
  /// "error" se reintenta (se actualiza), uno "timbrada" bloquea el re-timbrado.
  @@unique([emisorId, folioTicket])
  @@map("invoices")
  @@schema("public")
}

/// Archivo fiscal (XML/PDF) del CFDI, conservado como bytea (#4).
model InvoiceFile {
  id        String  @id @default(cuid())
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  /// "xml" | "pdf".
  tipo        String
  /// Bytes del archivo (XML o PDF ya decodificado de base64).
  contenido   Bytes
  /// Content-Type para servir la descarga (application/xml | application/pdf).
  contentType String

  createdAt DateTime @default(now())

  @@unique([invoiceId, tipo])
  @@map("invoice_files")
  @@schema("public")
}

/// Catálogo del SAT sembrado en BD (#6): c_RegimenFiscal, c_UsoCFDI, c_FormaPago.
model CatalogoSat {
  id          String @id @default(cuid())
  /// "regimenFiscal" | "usoCfdi" | "formaPago".
  tipo        String
  clave       String
  descripcion String
  /// Orden de presentación en el dropdown.
  orden       Int    @default(0)

  @@unique([tipo, clave])
  @@map("catalogos_sat")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────────────────
// ERP · Fase 2 — esquema `erp`
// ─────────────────────────────────────────────────────────────────────────────

/// Usuario del ERP (módulo único de usuarios). Fase 2 · rebanadas #1 y #2.
/// Autenticación por credenciales (Auth.js v5, sesión JWT): `authorize` busca por
/// `email`, compara `passwordHash` con bcrypt y exige `activo`. El acceso a cada
/// módulo y su rol viven en `moduleRoles`; el alcance por tienda en `stores`.
model User {
  id           String  @id @default(cuid())
  email        String  @unique
  nombre       String
  /// Hash bcrypt de la contraseña (nunca la contraseña en claro).
  passwordHash String
  /// Usuario desactivado: conserva historial pero no puede iniciar sesión.
  activo       Boolean @default(true)
  /// Administrador del ERP: gestiona el directorio de usuarios y las tiendas, y
  /// tiene acceso total a todos los módulos y tiendas (super-usuario).
  esAdmin      Boolean @default(false)

  moduleRoles UserModuleRole[]
  stores      UserStore[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("usuarios")
  @@schema("erp")
}

/// Los 4 módulos del ERP.
enum Modulo {
  GESTION
  POS
  FINANZAS
  PRONOSTICOS

  @@schema("erp")
}

/// Rol dentro de un módulo. LECTOR = solo lectura; OPERATIVO = + transacciones;
/// CONFIGURADOR = + datos maestros/precios/configuración del módulo.
enum Rol {
  CONFIGURADOR
  OPERATIVO
  LECTOR

  @@schema("erp")
}

/// Tienda (sucursal). Una empresa, varias tiendas. Dimensión operativa/reporte;
/// el catálogo/maestros se comparten y lo transaccional se filtra por tienda.
model Tienda {
  id        String  @id @default(cuid())
  codigo    String  @unique
  nombre    String
  direccion String?
  activo    Boolean @default(true)

  usuarios     UserStore[]
  inventarios  Inventario[]
  movimientos  Movimiento[]
  compras      Compra[]
  tickets      TicketPOS[]
  ventas       Venta[]
  ordenes      OrdenVenta[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tiendas")
  @@schema("erp")
}

/// Rol de un usuario en un módulo (uno por módulo).
model UserModuleRole {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  modulo Modulo
  rol    Rol

  @@unique([userId, modulo])
  @@map("usuario_modulo_rol")
  @@schema("erp")
}

/// Alcance de un usuario a una tienda. Sin filas: un CONFIGURADOR/admin ve todas;
/// un OPERATIVO/LECTOR sin tiendas no puede operar acciones por tienda.
model UserStore {
  id       String @id @default(cuid())
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  tienda   Tienda @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  tiendaId String

  @@unique([userId, tiendaId])
  @@map("usuario_tienda")
  @@schema("erp")
}

// ── Módulo 1 · Gestión — catálogos y datos maestros (rebanada #3) ────────────

/// Unidad de medida (kg, pza, l, …).
model Unidad {
  id           String        @id @default(cuid())
  codigo       String        @unique
  nombre       String
  ingredientes Ingrediente[]
  productos    Producto[]

  @@map("unidades")
  @@schema("erp")
}

/// Categoría de receta/producto (postres, bebidas, …). Eje del margen objetivo.
model Categoria {
  id        String           @id @default(cuid())
  nombre    String           @unique
  recetas   Receta[]
  productos Producto[]
  margenes  MargenObjetivo[]

  @@map("categorias")
  @@schema("erp")
}

/// Canal de venta (Tienda, Uber, …). Eje de precios, comisiones y margen objetivo.
model Canal {
  id              String           @id @default(cuid())
  nombre          String           @unique
  margenes        MargenObjetivo[]
  preciosReceta   PrecioReceta[]
  preciosProducto ProductoPrecio[]
  comisiones      Comision[]

  @@map("canales")
  @@schema("erp")
}

/// Ingrediente (materia prima). `costoCompra` = costo de compra general (editable,
/// base del costeo y del precio). El CPM por tienda llega en la rebanada #6.
model Ingrediente {
  id          String  @id @default(cuid())
  codigo      String  @unique
  nombre      String
  unidad      Unidad  @relation(fields: [unidadId], references: [id])
  unidadId    String
  /// Costo de compra general por unidad base.
  costoCompra Decimal @default(0) @db.Decimal(14, 6)
  /// Mínimo de compra (para redondeo en la explosión de compras, #11).
  minCompra   Decimal @default(0) @db.Decimal(14, 4)

  componentes     RecetaComponente[]
  semiComponentes SemiTerminadoComponente[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ingredientes")
  @@schema("erp")
}

/// Receta (producto vendible compuesto). El costo se calcula en vivo desde sus
/// componentes (no se guarda snapshot). Semi-terminados y tamaño: rebanada #4.
model Receta {
  id          String    @id @default(cuid())
  sku         String    @unique
  nombre      String
  categoria   Categoria @relation(fields: [categoriaId], references: [id])
  categoriaId String
  tamano      Tamano?   @relation(fields: [tamanoId], references: [id])
  tamanoId    String?

  componentes RecetaComponente[]
  precios     PrecioReceta[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("recetas")
  @@schema("erp")
}

/// Tamaño/presentación de una receta (Individual, Familiar, …). Eje de precios (#5).
model Tamano {
  id      String   @id @default(cuid())
  nombre  String   @unique
  recetas Receta[]

  @@map("tamanos")
  @@schema("erp")
}

/// Semi-terminado: preparación reutilizable y componible (incluso anidada) dentro
/// de recetas u otros semi-terminados. Su costo se calcula recursivamente.
model SemiTerminado {
  id     String @id @default(cuid())
  sku    String @unique
  nombre String

  componentes    SemiTerminadoComponente[] @relation("SemiPartes")
  usadoEnRecetas RecetaComponente[]
  usadoEnSemis   SemiTerminadoComponente[] @relation("SemiHijo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("semi_terminados")
  @@schema("erp")
}

/// Componente de un semi-terminado: un ingrediente XOR otro semi-terminado (hijo).
model SemiTerminadoComponente {
  id              String        @id @default(cuid())
  semiTerminado   SemiTerminado @relation("SemiPartes", fields: [semiTerminadoId], references: [id], onDelete: Cascade)
  semiTerminadoId String
  ingrediente     Ingrediente?  @relation(fields: [ingredienteId], references: [id])
  ingredienteId   String?
  hijo            SemiTerminado? @relation("SemiHijo", fields: [hijoId], references: [id])
  hijoId          String?
  cantidad        Decimal       @db.Decimal(14, 4)
  rendimiento     Decimal       @default(100) @db.Decimal(7, 4)

  @@map("semi_componentes")
  @@schema("erp")
}

/// Componente de una receta: un ingrediente XOR un semi-terminado. `cantidad` en
/// la unidad base; `rendimiento` (%) ajusta por merma (100 = sin ajuste).
model RecetaComponente {
  id              String         @id @default(cuid())
  receta          Receta         @relation(fields: [recetaId], references: [id], onDelete: Cascade)
  recetaId        String
  ingrediente     Ingrediente?   @relation(fields: [ingredienteId], references: [id])
  ingredienteId   String?
  semiTerminado   SemiTerminado? @relation(fields: [semiTerminadoId], references: [id])
  semiTerminadoId String?
  cantidad        Decimal        @db.Decimal(14, 4)
  rendimiento     Decimal        @default(100) @db.Decimal(7, 4)

  @@map("receta_componentes")
  @@schema("erp")
}

/// Margen objetivo por (categoría, canal): % usado para sugerir el precio de
/// venta a partir del costo de compra. Se guarda como número humano (60 = 60%).
model MargenObjetivo {
  id          String    @id @default(cuid())
  categoria   Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  categoriaId String
  canal       Canal     @relation(fields: [canalId], references: [id], onDelete: Cascade)
  canalId     String
  margen      Decimal   @db.Decimal(7, 4)

  @@unique([categoriaId, canalId])
  @@map("margen_objetivo")
  @@schema("erp")
}

// ── Rebanada #5 · productos, precios por canal y comisiones ──────────────────

/// Producto no-receta (artículo vendible que no se compone de ingredientes).
model Producto {
  id          String           @id @default(cuid())
  codigo      String           @unique
  descripcion String
  categoria   Categoria        @relation(fields: [categoriaId], references: [id])
  categoriaId String
  unidad      Unidad           @relation(fields: [unidadId], references: [id])
  unidadId    String
  costo       Decimal          @default(0) @db.Decimal(14, 6)
  minCompra   Decimal          @default(0) @db.Decimal(14, 4)
  precios     ProductoPrecio[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("productos")
  @@schema("erp")
}

/// Precio de venta (con IVA) de un producto por canal.
model ProductoPrecio {
  id         String   @id @default(cuid())
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  productoId String
  canal      Canal    @relation(fields: [canalId], references: [id], onDelete: Cascade)
  canalId    String
  precio     Decimal  @db.Decimal(14, 2)

  @@unique([productoId, canalId])
  @@map("producto_precios")
  @@schema("erp")
}

/// Precio de venta (con IVA) de una receta por canal.
model PrecioReceta {
  id       String  @id @default(cuid())
  receta   Receta  @relation(fields: [recetaId], references: [id], onDelete: Cascade)
  recetaId String
  canal    Canal   @relation(fields: [canalId], references: [id], onDelete: Cascade)
  canalId  String
  precio   Decimal @db.Decimal(14, 2)

  @@unique([recetaId, canalId])
  @@map("precio_recetas")
  @@schema("erp")
}

/// Medio de pago (Efectivo, Tarjeta, …). Junto con el canal define la comisión.
model MedioPago {
  id         String     @id @default(cuid())
  nombre     String     @unique
  comisiones Comision[]

  @@map("medios_pago")
  @@schema("erp")
}

/// Comisión (%) por (canal, medio de pago). La aplica el POS y las finanzas.
model Comision {
  id          String    @id @default(cuid())
  canal       Canal     @relation(fields: [canalId], references: [id], onDelete: Cascade)
  canalId     String
  medioPago   MedioPago @relation(fields: [medioPagoId], references: [id], onDelete: Cascade)
  medioPagoId String
  comisionPct Decimal   @db.Decimal(7, 4)

  @@unique([canalId, medioPagoId])
  @@map("comisiones")
  @@schema("erp")
}

// ── Rebanada #6 · inventario, movimientos y compras (CPM por tienda) ─────────

enum TipoItem {
  INGREDIENTE
  PRODUCTO

  @@schema("erp")
}

enum TipoMovimiento {
  COMPRA
  VENTA
  DEVOLUCION
  AJUSTE
  MERMA

  @@schema("erp")
}

enum EstadoCompra {
  PENDIENTE
  PAGADA
  CANCELADA

  @@schema("erp")
}

/// Existencia por (tienda, código) con costo promedio móvil (CPM/MAP). Las hojas
/// con costo real son ingredientes y productos; las recetas se costean en vivo.
model Inventario {
  id         String   @id @default(cuid())
  tienda     Tienda   @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  tiendaId   String
  codigo     String
  nombre     String
  tipo       TipoItem
  stock      Decimal  @default(0) @db.Decimal(14, 4)
  cpm        Decimal  @default(0) @db.Decimal(14, 6)
  valorTotal Decimal  @default(0) @db.Decimal(14, 2)

  updatedAt DateTime @updatedAt

  @@unique([tiendaId, codigo])
  @@map("inventario")
  @@schema("erp")
}

/// Asiento del kardex: cada entrada/salida deja un movimiento firmado.
model Movimiento {
  id             String         @id @default(cuid())
  tienda         Tienda         @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  tiendaId       String
  codigo         String
  nombre         String
  tipoMovimiento TipoMovimiento
  /// Cantidad firmada: + entrada, − salida.
  qty            Decimal        @db.Decimal(14, 4)
  cpm            Decimal        @db.Decimal(14, 6)
  /// Costo del movimiento (firmado), al CPM aplicable.
  costoTotal     Decimal        @db.Decimal(14, 2)
  /// Referencia opcional al origen (p.ej. ticket POS, compra).
  refTipo        String?
  refId          String?
  fecha          DateTime       @default(now())

  @@index([tiendaId, codigo, fecha])
  @@map("movimientos")
  @@schema("erp")
}

/// Medio de compra (proveedor/forma): define días de crédito para cuentas por pagar.
model MedioCompra {
  id          String   @id @default(cuid())
  nombre      String   @unique
  diasCredito Int      @default(0)
  compras     Compra[]

  @@map("medios_compra")
  @@schema("erp")
}

/// Compra (entrada de inventario) y su cuenta por pagar.
model Compra {
  id            String       @id @default(cuid())
  tienda        Tienda       @relation(fields: [tiendaId], references: [id], onDelete: Cascade)
  tiendaId      String
  codigo        String
  descripcion   String
  cantidad      Decimal      @db.Decimal(14, 4)
  costoUnitario Decimal      @db.Decimal(14, 6)
  monto         Decimal      @db.Decimal(14, 2)
  medioCompra   MedioCompra? @relation(fields: [medioCompraId], references: [id])
  medioCompraId String?
  estado        EstadoCompra @default(PENDIENTE)
  fechaCompra   DateTime     @default(now())
  fechaPago     DateTime?

  @@index([tiendaId, fechaCompra])
  @@map("compras")
  @@schema("erp")
}

// ── Rebanada #7 · Punto de Venta (POS) ───────────────────────────────────────

enum TipoVenta {
  VENTA
  DEVOLUCION

  @@schema("erp")
}

/// Encabezado del ticket POS (folio único). Liga 1:1 con la autofactura del
/// portal por `folioTicket` (rebanada #10).
model TicketPOS {
  id             String    @id @default(cuid())
  folio          String    @unique
  tienda         Tienda    @relation(fields: [tiendaId], references: [id])
  tiendaId       String
  usuarioId      String
  canalId        String
  medioPagoId    String?
  tipo           TipoVenta @default(VENTA)
  total          Decimal   @db.Decimal(14, 2)
  subtotalSinIva Decimal   @db.Decimal(14, 2)
  iva            Decimal   @db.Decimal(14, 2)
  comisionMonto  Decimal   @db.Decimal(14, 2)
  costo          Decimal   @db.Decimal(14, 2)
  utilidad       Decimal   @db.Decimal(14, 2)
  /// Folio para autofacturación en el portal (#10). Igual a `folio`.
  folioTicket    String?
  fecha          DateTime  @default(now())

  lineas Venta[]

  @@index([tiendaId, fecha])
  @@map("tickets_pos")
  @@schema("erp")
}

/// Línea de venta del POS (un renglón por artículo del ticket).
model Venta {
  id             String    @id @default(cuid())
  ticket         TicketPOS @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId       String
  tienda         Tienda    @relation(fields: [tiendaId], references: [id])
  tiendaId       String
  fecha          DateTime  @default(now())
  tipo           TipoVenta @default(VENTA)
  usuarioId      String
  canalId        String
  medioPagoId    String?
  codigo         String
  articulo       String
  qty            Decimal   @db.Decimal(14, 4)
  precioUnit     Decimal   @db.Decimal(14, 2)
  totalVenta     Decimal   @db.Decimal(14, 2)
  subtotalSinIva Decimal   @db.Decimal(14, 2)
  iva            Decimal   @db.Decimal(14, 2)
  comisionPct    Decimal   @db.Decimal(7, 4)
  comisionMonto  Decimal   @db.Decimal(14, 2)
  cpm            Decimal   @db.Decimal(14, 6)
  costo          Decimal   @db.Decimal(14, 2)
  utilidadMonto  Decimal   @db.Decimal(14, 2)
  utilidadPct    Decimal   @db.Decimal(7, 4)

  @@index([tiendaId, fecha])
  @@map("ventas")
  @@schema("erp")
}

// ── Rebanada #8 · clientes y órdenes de venta (pedidos) ──────────────────────

enum EstadoEntrega {
  PENDIENTE
  ENTREGADO
  CANCELADO

  @@schema("erp")
}

enum EstadoFactura {
  SIN_FACTURA
  FACTURADA
  CANCELADA

  @@schema("erp")
}

enum EstadoCobro {
  PENDIENTE
  PAGADO
  CANCELADO

  @@schema("erp")
}

/// Cliente (para órdenes de venta / pedidos B2B).
model Cliente {
  id             String       @id @default(cuid())
  nombre         String
  rfc            String?
  correos        String[]
  telefono       String?
  diasPago       Int?
  dirFacturacion String?
  dirEntrega     String?
  banco          String?
  clabe          String?
  ordenes        OrdenVenta[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clientes")
  @@schema("erp")
}

/// Orden de venta (pedido por entregar) con triple seguimiento de estado.
model OrdenVenta {
  id                String        @id @default(cuid())
  folio             String        @unique
  fecha             DateTime      @default(now())
  cliente           Cliente       @relation(fields: [clienteId], references: [id])
  clienteId         String
  tienda            Tienda        @relation(fields: [tiendaId], references: [id])
  tiendaId          String
  usuarioId         String
  totalPedido       Decimal       @db.Decimal(14, 2)
  estadoEntrega     EstadoEntrega @default(PENDIENTE)
  estadoFactura     EstadoFactura @default(SIN_FACTURA)
  estadoCobro       EstadoCobro   @default(PENDIENTE)
  fechaEntrega      DateTime?
  fechaFacturacion  DateTime?
  fechaPago         DateTime?
  /// Fecha estimada de pago (fecha + díasPago del cliente).
  fechaPagoEstimada DateTime?
  folioFactura      String?

  lineas OrdenVentaLinea[]

  @@index([tiendaId, fecha])
  @@map("ordenes_venta")
  @@schema("erp")
}

/// Renglón de una orden de venta.
model OrdenVentaLinea {
  id         String     @id @default(cuid())
  orden      OrdenVenta @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  ordenId    String
  codigo     String
  articulo   String
  qty        Decimal    @db.Decimal(14, 4)
  precioUnit Decimal    @db.Decimal(14, 2)
  subtotal   Decimal    @db.Decimal(14, 2)

  @@map("orden_venta_lineas")
  @@schema("erp")
}

// ── Rebanada #9 · gastos y estado de resultados ──────────────────────────────

enum TipoER {
  GASTO_OPERATIVO_ADMIN
  GASTO_OPERATIVO_VENTAS
  OTRO_GASTO
  OTRO_INGRESO
  GASTO_FINANCIERO
  INGRESO_FINANCIERO
  IMPUESTO

  @@schema("erp")
}

enum Periodicidad {
  UNICA
  QUINCENAL
  MENSUAL
  BIMESTRAL
  SEMESTRAL
  ANUAL

  @@schema("erp")
}

/// Catálogo de categorías de gasto, con su mapeo al estado de resultados (tipoER)
/// y porcentajes de IVA/ISR para auto-cálculo al capturar.
model CategoriaGasto {
  id     String  @id @default(cuid())
  nombre String  @unique
  tipoER TipoER
  cuenta String?
  ivaPct Decimal @default(16) @db.Decimal(7, 4)
  isrPct Decimal @default(0) @db.Decimal(7, 4)
  gastos Gasto[]

  @@map("categorias_gasto")
  @@schema("erp")
}

/// Gasto (o ingreso no operativo). `tiendaId` nulo = gasto general (todas).
model Gasto {
  id               String         @id @default(cuid())
  fecha            DateTime       @default(now())
  categoriaGasto   CategoriaGasto @relation(fields: [categoriaGastoId], references: [id])
  categoriaGastoId String
  descripcion      String
  monto            Decimal        @db.Decimal(14, 2)
  iva              Decimal        @default(0) @db.Decimal(14, 2)
  isr              Decimal        @default(0) @db.Decimal(14, 2)
  tiendaId         String?
  periodicidad     Periodicidad   @default(UNICA)

  createdAt DateTime @default(now())

  @@index([fecha])
  @@map("gastos")
  @@schema("erp")
}

// ── Rebanada #11 · pronósticos (ventas y explosión de compras) ───────────────

enum MetodoPronostico {
  LINEAL
  EXPONENCIAL
  PLANO

  @@schema("erp")
}

enum EstadoPronostico {
  BORRADOR
  CONFIRMADO

  @@schema("erp")
}

/// Agregado semanal de ventas (materializado desde Venta). Base del pronóstico.
model VentaSemanal {
  id            String  @id @default(cuid())
  anio          Int
  semana        Int
  tiendaId      String
  canalId       String
  codigo        String
  articulo      String
  ventas        Decimal @db.Decimal(14, 2)
  costo         Decimal @db.Decimal(14, 2)
  utilidad      Decimal @db.Decimal(14, 2)
  unidades      Decimal @db.Decimal(14, 4)
  transacciones Int     @default(0)

  @@unique([anio, semana, tiendaId, canalId, codigo])
  @@map("ventas_semanales")
  @@schema("erp")
}

/// Corrida de pronóstico (parámetros + resultados). Se confirma para bloquear.
model Pronostico {
  id               String           @id @default(cuid())
  tiendaId         String
  metodo           MetodoPronostico
  semanasHistoria  Int
  horizonteSemanas Int
  usaEstacional    Boolean          @default(false)
  usaTendencia     Boolean          @default(false)
  crecimiento      Decimal          @default(1) @db.Decimal(7, 4)
  estado           EstadoPronostico @default(BORRADOR)
  createdAt        DateTime         @default(now())

  lineas  PronosticoLinea[]
  compras PronosticoCompra[]
  gastos  PronosticoGasto[]

  @@map("pronosticos")
  @@schema("erp")
}

/// Gasto proyectado en el horizonte (desde gastos recurrentes por periodicidad).
model PronosticoGasto {
  id           String       @id @default(cuid())
  pronostico   Pronostico   @relation(fields: [pronosticoId], references: [id], onDelete: Cascade)
  pronosticoId String
  categoria    String
  periodicidad Periodicidad
  ocurrencias  Int
  monto        Decimal      @db.Decimal(14, 2)

  @@map("pronostico_gastos")
  @@schema("erp")
}

/// Línea de pronóstico de ventas por artículo (receta/producto).
model PronosticoLinea {
  id           String     @id @default(cuid())
  pronostico   Pronostico @relation(fields: [pronosticoId], references: [id], onDelete: Cascade)
  pronosticoId String
  codigo       String
  articulo     String
  unidades     Decimal    @db.Decimal(14, 4)
  ventas       Decimal    @db.Decimal(14, 2)
  costo        Decimal    @db.Decimal(14, 2)

  @@map("pronostico_lineas")
  @@schema("erp")
}

/// Compra pronosticada (explosión BOM a ingredientes), con redondeo a mínimo.
model PronosticoCompra {
  id                 String     @id @default(cuid())
  pronostico         Pronostico @relation(fields: [pronosticoId], references: [id], onDelete: Cascade)
  pronosticoId       String
  ingredienteCodigo  String
  nombre             String
  cantidad           Decimal    @db.Decimal(14, 4)
  cantidadRedondeada Decimal    @db.Decimal(14, 4)
  costoEstimado      Decimal    @db.Decimal(14, 2)

  @@map("pronostico_compras")
  @@schema("erp")
}

/// Bitácora/candado del pronóstico semanal automático (Vercel Cron, #12).
model PronStatus {
  id     String   @id @default(cuid())
  anio   Int
  semana Int
  ranAt  DateTime @default(now())

  @@unique([anio, semana])
  @@map("pron_status")
  @@schema("erp")
}
