# Copia a .env y ajusta si cambias credenciales en docker-compose.yml
DATABASE_URL="postgresql://erpyou:erpyou@localhost:5432/erpyou?schema=public"

# Facturama (API Multiemisor). Las cuentas sandbox y producción son independientes.
# Usadas por el CLI de alta de emisor (npm run emisor:alta) y por el timbrado.
FACTURAMA_USER=""
FACTURAMA_PASSWORD=""
FACTURAMA_ENV="sandbox"   # "sandbox" | "production"
