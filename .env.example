# Copia a .env y ajusta si cambias credenciales en docker-compose.yml
DATABASE_URL="postgresql://erpyou:erpyou@localhost:5432/erpyou?schema=public"
# Conexión directa para migraciones (en Neon: la URL no-pooled). En local = DATABASE_URL.
DIRECT_URL="postgresql://erpyou:erpyou@localhost:5432/erpyou?schema=public"

# Auth.js v5 (ERP Fase 2). Secreto para firmar la sesión JWT.
# Genera uno con: npx auth secret   (o: openssl rand -base64 33)
AUTH_SECRET=""

# Cron del pronóstico semanal (Vercel Cron, #12). El endpoint /api/cron/forecast
# exige Authorization: Bearer <CRON_SECRET>. En Vercel, define esta variable y el
# cron la envía automáticamente. Genera uno con: openssl rand -base64 33
CRON_SECRET=""

# Facturama (API Multiemisor). Las cuentas sandbox y producción son independientes.
# Usadas por el CLI de alta de emisor (npm run emisor:alta) y por el timbrado.
FACTURAMA_USER=""
FACTURAMA_PASSWORD=""
FACTURAMA_ENV="sandbox"   # "sandbox" | "production"

# Resend (entrega por correo, #5). Opcional: si quedan vacíos no se envía correo
# (el timbrado y la descarga siguen funcionando). EMAIL_FROM debe pertenecer a un
# dominio verificado en Resend (en pruebas sirve onboarding@resend.dev).
RESEND_API_KEY=""
EMAIL_FROM=""             # p.ej. "Panadería Demo <facturas@tudominio.mx>"
